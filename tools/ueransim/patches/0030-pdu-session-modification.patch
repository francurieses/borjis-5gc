+void NgapTask::receiveSessionResourceModifyRequest(int amfId, ASN_NGAP_PDUSessionResourceModifyRequest *msg)
+{
+    // 5GC Rel-17 mod: stock UERANSIM has no handler for NGAP PDU Session Resource Modify
+    // (it logs "Unhandled NGAP initiating-message"), so the embedded 5GSM PDU SESSION
+    // MODIFICATION COMMAND (0xCB) never reaches the UE. This forwards each item's NAS-PDU to
+    // the UE and replies with a PDU Session Resource Modify Response. Ref: TS 23.502 §4.3.3.2,
+    // TS 38.413 §8.2.1.
+    m_logger->debug("PDU Session Resource Modify Request received");
+
+    auto *ue = findUeByNgapIdPair(amfId, ngap_utils::FindNgapIdPair(msg));
+    if (ue == nullptr)
+        return;
+
+    std::vector<ASN_NGAP_PDUSessionResourceModifyItemModRes *> modifiedList;
+
+    auto *reqIe = asn::ngap::GetProtocolIe(msg, ASN_NGAP_ProtocolIE_ID_id_PDUSessionResourceModifyListModReq);
+    if (reqIe)
+    {
+        auto &list = reqIe->PDUSessionResourceModifyListModReq.list;
+        for (int i = 0; i < list.count; i++)
+        {
+            auto &item = list.array[i];
+
+            // Deliver the embedded 5GSM Modification Command (0xCB) to the UE NAS layer.
+            if (item->nAS_PDU != nullptr)
+                deliverDownlinkNas(ue->ctxId, asn::GetOctetString(*item->nAS_PDU));
+
+            // Acknowledge the session in the response with a minimal (empty) transfer.
+            auto *tr = asn::New<ASN_NGAP_PDUSessionResourceModifyResponseTransfer>();
+            OctetString encodedTr =
+                ngap_encode::EncodeS(asn_DEF_ASN_NGAP_PDUSessionResourceModifyResponseTransfer, tr);
+            asn::Free(asn_DEF_ASN_NGAP_PDUSessionResourceModifyResponseTransfer, tr);
+
+            auto *res = asn::New<ASN_NGAP_PDUSessionResourceModifyItemModRes>();
+            res->pDUSessionID = item->pDUSessionID;
+            asn::SetOctetString(res->pDUSessionResourceModifyResponseTransfer, encodedTr);
+            modifiedList.push_back(res);
+        }
+    }
+
+    std::vector<ASN_NGAP_PDUSessionResourceModifyResponseIEs *> responseIes;
+    if (!modifiedList.empty())
+    {
+        auto *ie = asn::New<ASN_NGAP_PDUSessionResourceModifyResponseIEs>();
+        ie->id = ASN_NGAP_ProtocolIE_ID_id_PDUSessionResourceModifyListModRes;
+        ie->criticality = ASN_NGAP_Criticality_ignore;
+        ie->value.present =
+            ASN_NGAP_PDUSessionResourceModifyResponseIEs__value_PR_PDUSessionResourceModifyListModRes;
+
+        for (auto &item : modifiedList)
+            asn::SequenceAdd(ie->value.choice.PDUSessionResourceModifyListModRes, item);
+
+        responseIes.push_back(ie);
+    }
+
+    auto *response = asn::ngap::NewMessagePdu<ASN_NGAP_PDUSessionResourceModifyResponse>(responseIes);
+    sendNgapUeAssociated(ue->ctxId, response);
+}
