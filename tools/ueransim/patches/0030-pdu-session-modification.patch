+//
+// 5GC Rel-17 modification — PDU Session Modification (TS 23.502 §4.3.3).
+//
+// Stock UERANSIM v3.2.8 decodes the PDU SESSION MODIFICATION COMMAND (0xCB) but
+// has no handler — receiveSmMessage logs "Unhandled NAS SM message". It also has
+// no nr-cli "ps-modify". This adds:
+//   * receiveModificationCommand: apply the authorized QoS and reply with a
+//     PDU SESSION MODIFICATION COMPLETE (0xCC), closing the §4.3.3.2 NW-initiated
+//     procedure (the network sends the command with PTI=0).
+//   * sendModificationRequest: nr-cli "ps-modify" sends a UE-requested
+//     PDU SESSION MODIFICATION REQUEST (0xC9) for the §4.3.3.1 procedure.
+//
+
+#include "sm.hpp"
+
+#include <lib/nas/utils.hpp>
+#include <ue/nas/mm/mm.hpp>
+
+namespace nr::ue
+{
+
+void NasSm::receiveModificationCommand(const nas::PduSessionModificationCommand &msg)
+{
+    m_logger->debug("PDU Session Modification Command received");
+
+    int psi = msg.pduSessionId;
+    if (psi < PduSession::MIN_ID || psi > PduSession::MAX_ID)
+    {
+        m_logger->err("Modification Command with invalid PSI [%d]", psi);
+        return;
+    }
+
+    auto &pduSession = m_pduSessions[psi];
+    if (pduSession == nullptr || pduSession->psState != EPsState::ACTIVE)
+    {
+        m_logger->err("Modification Command for inactive PSI [%d]", psi);
+        sendSmCause(nas::ESmCause::MESSAGE_TYPE_NOT_COMPATIBLE_WITH_THE_PROTOCOL_STATE, msg.pti, psi);
+        return;
+    }
+
+    // Apply the authorized QoS (network-initiated, TS 23.502 §4.3.3.2 step 5).
+    if (msg.sessionAmbr.has_value())
+        pduSession->sessionAmbr = nas::utils::DeepCopyIe(*msg.sessionAmbr);
+    if (msg.authorizedQoSRules.has_value())
+        pduSession->authorizedQoSRules = nas::utils::DeepCopyIe(*msg.authorizedQoSRules);
+    if (msg.authorizedQoSFlowDescriptions.has_value())
+        pduSession->authorizedQoSFlowDescriptions = nas::utils::DeepCopyIe(*msg.authorizedQoSFlowDescriptions);
+
+    m_logger->info("PDU Session [%d] QoS modified by the network%s%s (PTI %d)", psi,
+                   msg.sessionAmbr.has_value() ? " [Session-AMBR]" : "",
+                   msg.authorizedQoSFlowDescriptions.has_value() ? " [QoS flow descriptions]" : "", msg.pti);
+
+    // Acknowledge with PDU SESSION MODIFICATION COMPLETE (0xCC), echoing the PTI.
+    nas::PduSessionModificationComplete complete;
+    complete.pti = msg.pti;
+    complete.pduSessionId = psi;
+
+    m_logger->info("Sending PDU Session Modification Complete for PSI [%d]", psi);
+    sendSmMessage(psi, complete);
+}
+
+void NasSm::sendModificationRequest(int psi, std::optional<int> requestedFiveQi)
+{
+    if (psi < PduSession::MIN_ID || psi > PduSession::MAX_ID)
+    {
+        m_logger->err("Cannot modify PDU session: invalid PSI [%d]", psi);
+        return;
+    }
+
+    auto &pduSession = m_pduSessions[psi];
+    if (pduSession == nullptr || pduSession->psState != EPsState::ACTIVE)
+    {
+        m_logger->err("Cannot modify PDU session: PSI [%d] is not active", psi);
+        return;
+    }
+
+    if (m_mm->m_rmState != ERmState::RM_REGISTERED)
+    {
+        m_logger->err("PDU session modification could not be triggered, UE is not registered");
+        return;
+    }
+
+    int pti = allocateProcedureTransactionId();
+    if (pti == 0)
+        return;
+
+    if (requestedFiveQi.has_value())
+        m_logger->info("Requesting modification of PSI [%d] (requested 5QI %d — network authorizes the actual value)",
+                       psi, *requestedFiveQi);
+    else
+        m_logger->info("Requesting modification of PSI [%d]", psi);
+
+    auto req = std::make_unique<nas::PduSessionModificationRequest>();
+    req->pti = pti;
+    req->pduSessionId = psi;
+
+    auto &pt = m_procedureTransactions[pti];
+    pt.state = EPtState::PENDING;
+    pt.timer = newTransactionTimer(3581);
+    pt.message = std::move(req);
+    pt.psi = psi;
+
+    sendSmMessage(psi, *pt.message);
+}
+
+} // namespace nr::ue
