--- a/src/ue/types.hpp
+++ b/src/ue/types.hpp
@@ -642,7 +642,12 @@ enum class ENasTransportHint
     PDU_SESSION_RELEASE_COMMAND,
     PDU_SESSION_RELEASE_COMPLETE,
 
-    FIVEG_SM_STATUS
+    FIVEG_SM_STATUS,
+
+    // 5GC Rel-17 mod: UE policy delivery service (TS 24.501 Annex D). Carried in an
+    // UL NAS TRANSPORT with payload container type "UE policy container" (0x05);
+    // not subject to UAC nor to the N1-SM/SMS non-allowed-area restriction.
+    UE_POLICY_DELIVERY
 };
 
 Json ToJson(const ECmState &state);
