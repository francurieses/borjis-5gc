 // Render a decoded policy as a human-readable multi-line string (for logs / nr-cli).
 std::string UrspPolicyToString(const UrspPolicy &policy);
 
+// Evaluate the URSP policy for a target token (a DNN, application name, or FQDN
+// substring). Rules are considered in ascending precedence (lower value = higher
+// priority, TS 24.526 §5.2). A rule applies when its traffic descriptor is
+// match-all, an FQDN component contains the target, or one of its route selection
+// descriptors routes to a DNN equal to the target. Returns the selected route
+// selection descriptor (preferring the one whose DNN equals the target) and sets
+// `matchInfo` to a human-readable reason, or nullptr when no rule applies.
+const UrspRouteSelectionDescriptor *MatchUrspTarget(const UrspPolicy &policy, const std::string &target,
+                                                    std::string &matchInfo);
+
 } // namespace nr::ue
