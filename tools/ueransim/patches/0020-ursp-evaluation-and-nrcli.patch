+const UrspRouteSelectionDescriptor *MatchUrspTarget(const UrspPolicy &policy, const std::string &target,
+                                                    std::string &matchInfo)
+{
+    // Consider rules in ascending precedence (lower value = higher priority).
+    std::vector<const UrspRule *> ordered;
+    ordered.reserve(policy.rules.size());
+    for (const auto &r : policy.rules)
+        ordered.push_back(&r);
+    std::sort(ordered.begin(), ordered.end(),
+              [](const UrspRule *a, const UrspRule *b) { return a->precedence < b->precedence; });
+
+    for (const UrspRule *rule : ordered)
+    {
+        if (rule->rsds.empty())
+            continue;
+
+        // Prefer an RSD that routes explicitly to the requested DNN.
+        for (const auto &rsd : rule->rsds)
+        {
+            if (rsd.dnn && *rsd.dnn == target)
+            {
+                matchInfo = "rule precedence " + std::to_string(rule->precedence) + " matched on DNN '" + target + "'";
+                return &rsd;
+            }
+        }
+
+        // Otherwise, does the traffic descriptor select this rule for the target?
+        bool applies = rule->td.matchAll;
+        std::string why = "match-all traffic descriptor";
+        if (!applies)
+        {
+            for (const auto &f : rule->td.fqdns)
+            {
+                if (f.find(target) != std::string::npos)
+                {
+                    applies = true;
+                    why = "FQDN '" + f + "' contains '" + target + "'";
+                    break;
+                }
+            }
+        }
+        if (applies)
+        {
+            matchInfo = "rule precedence " + std::to_string(rule->precedence) + " matched on " + why;
+            return &rule->rsds.front();
+        }
+    }
+
+    matchInfo = "no URSP rule matches '" + target + "'";
+    return nullptr;
+}
