# MCP server — host/stdio configuration for local clients (e.g. Claude Code).
#
# Copy this file to mcp/config/local.yaml and fill in the absolute paths
# to your local PKI files (generated by `make pki`).
#
# Use this when Claude Code launches the binary directly over stdio (no OAuth,
# unlike the remote SSE transport). Upstreams point at the stack's published
# host ports; the NRF SBI is reached over mTLS using the dev PKI.

transport: stdio

# Upstreams via published host ports (docker compose --profile core ... up).
nrf_addr: "https://localhost:8000"
amf_addr: "http://localhost:9002"
jaeger_addr: "http://localhost:16686"
prometheus_addr: "http://localhost:9090"

# TLS material for the NRF SBI (mTLS). The mcp cert SANs include localhost/127.0.0.1.
# Set these to the absolute path of your pki/ directory after running `make pki`.
ca_file: "/path/to/your/repo/pki/ca.crt"
client_cert_file: "/path/to/your/repo/pki/mcp.crt"
client_key_file: "/path/to/your/repo/pki/mcp.key"
