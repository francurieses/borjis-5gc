# Copy to .env to override docker-compose.yml defaults.
# The values below are dev defaults — change them for any real deployment.

# PostgreSQL
POSTGRES_USER=5gc
POSTGRES_PASSWORD=change-me-before-production
POSTGRES_DB=5gc

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-before-production

# UERANSIM — number of simulated UEs (default: 1)
UE_COUNT=1

# MCP bearer token (leave empty to disable auth in dev)
# MCP_BEARER_TOKEN=
